{
  "name": "@pierre/aborium-diff-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:deps && vite build",
    "build:deps": "bun run build:deps:diffs",
    "build:deps:diffs": "output=$(cd ../../packages/diffs && bun run build 2>&1) && echo '[diffs] Successfully cleaned and built.' || (echo \"$output\" >&2 && exit 1)",
    "build-types": "bun run build:deps && tsgo --build",
    "dev": "bun run build:deps && bun run dev:vite",
    "dev:vite": "vite --host --clearScreen=false",
    "preview": "vite preview",
    "start": "vite preview",
    "prod": "bun run build && bun run start",
    "tsc": "bun run build:deps && tsgo --noEmit --pretty"
  },
  "dependencies": {
    "@arborium/arborium": "catalog:",
    "@pierre/diffs": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
